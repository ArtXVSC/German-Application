<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Starke Verben — Verbes irréguliers allemands</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F5F0E8;
    --ink: #1A1A1A;
    --accent: #D94F3D;
    --accent2: #2D6A8F;
    --accent3: #E8B84B;
    --card: #FFFFFF;
    --muted: #888;
    --border: #E0D8CC;
    --correct: #3A9E6A;
    --wrong: #D94F3D;
    --mono: 'DM Mono', monospace;
    --sans: 'DM Sans', sans-serif;
    --display: 'Bebas Neue', sans-serif;
  }
 
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
  }
 
  /* ──── HEADER ──── */
  header {
    background: var(--ink);
    color: white;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
 
  .logo {
    font-family: var(--display);
    font-size: 2rem;
    letter-spacing: 2px;
    color: var(--accent3);
  }
  .logo span { color: white; }
 
  nav { display: flex; gap: .5rem; }
 
  .tab-btn {
    background: none;
    border: 2px solid transparent;
    color: #aaa;
    font-family: var(--sans);
    font-weight: 500;
    font-size: .85rem;
    padding: .4rem 1.1rem;
    border-radius: 4px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all .2s;
  }
  .tab-btn:hover { color: white; border-color: rgba(255,255,255,.3); }
  .tab-btn.active { color: var(--ink); background: var(--accent3); border-color: var(--accent3); }
 
  /* ──── HERO ──── */
  .hero {
    background: var(--ink);
    color: white;
    padding: 3rem 2rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: 'VERBEN';
    position: absolute;
    font-family: var(--display);
    font-size: clamp(6rem, 20vw, 16rem);
    color: rgba(255,255,255,.04);
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }
  .hero h1 {
    font-family: var(--display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: .8rem;
  }
  .hero h1 em { color: var(--accent3); font-style: normal; }
  .hero p { color: #aaa; font-size: 1rem; font-weight: 300; }
 
  /* ──── MAIN ──── */
  main { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
 
  /* ──── VIEW PANELS ──── */
  .view { display: none; }
  .view.active { display: block; }
 
  /* ──── TABLE VIEW ──── */
  .controls {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
 
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
  }
  .search-wrap svg {
    position: absolute;
    left: .9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
  }
  input[type="search"] {
    width: 100%;
    padding: .65rem 1rem .65rem 2.5rem;
    border: 2px solid var(--border);
    border-radius: 6px;
    font-family: var(--sans);
    font-size: .95rem;
    background: white;
    outline: none;
    transition: border-color .2s;
  }
  input[type="search"]:focus { border-color: var(--accent2); }
 
  .filter-group { display: flex; gap: .4rem; flex-wrap: wrap; }
  .filter-btn {
    padding: .45rem .9rem;
    border: 2px solid var(--border);
    border-radius: 100px;
    background: white;
    font-size: .8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .5px;
    cursor: pointer;
    transition: all .15s;
    color: var(--muted);
  }
  .filter-btn:hover { border-color: var(--accent2); color: var(--accent2); }
  .filter-btn.active { background: var(--accent2); border-color: var(--accent2); color: white; }
 
  .verb-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 6px;
  }
 
  .verb-table thead tr th {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--muted);
    padding: .4rem 1rem;
    text-align: left;
  }
 
  .verb-table tbody tr {
    background: white;
    transition: transform .1s, box-shadow .1s;
    cursor: default;
  }
  .verb-table tbody tr:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,.08);
  }
 
  .verb-table td {
    padding: .9rem 1rem;
    border: none;
  }
  .verb-table td:first-child { border-radius: 8px 0 0 8px; }
  .verb-table td:last-child  { border-radius: 0 8px 8px 0; }
 
  .v-inf {
    font-family: var(--mono);
    font-weight: 500;
    font-size: 1rem;
    color: var(--accent);
  }
  .v-pret, .v-part {
    font-family: var(--mono);
    font-size: .92rem;
    color: var(--accent2);
  }
  .v-pret  { color: var(--accent2); }
  .v-part  { color: var(--correct); }
  .v-trans { font-size: .88rem; color: var(--muted); font-weight: 300; }
  .v-cat {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: .2rem .6rem;
    border-radius: 100px;
    background: var(--bg);
    color: var(--muted);
  }
 
  .count-label {
    font-size: .82rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .count-label strong { color: var(--ink); }
 
  /* ──── FLASHCARD VIEW ──── */
  .fc-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1rem;
  }
 
  .fc-progress {
    width: 100%;
    max-width: 560px;
    height: 6px;
    background: var(--border);
    border-radius: 100px;
    overflow: hidden;
  }
  .fc-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent2), var(--accent3));
    border-radius: 100px;
    transition: width .4s ease;
  }
 
  .fc-counter {
    font-size: .82rem;
    color: var(--muted);
    font-family: var(--mono);
  }
 
  .card {
    width: 100%;
    max-width: 560px;
    height: 300px;
    perspective: 1000px;
    cursor: pointer;
  }
 
  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform .55s cubic-bezier(.4,0,.2,1);
  }
  .card.flipped .card-inner { transform: rotateY(180deg); }
 
  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .card-front {
    background: var(--ink);
    color: white;
  }
  .card-back {
    background: white;
    transform: rotateY(180deg);
    border: 3px solid var(--border);
  }
 
  .card-hint {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: .4;
    margin-bottom: .8rem;
    font-weight: 600;
  }
  .card-word {
    font-family: var(--display);
    font-size: 3.5rem;
    letter-spacing: 2px;
    line-height: 1;
    text-align: center;
    color: var(--accent3);
  }
  .card-sub {
    font-size: .9rem;
    opacity: .5;
    margin-top: .4rem;
  }
  .card-flip-hint {
    position: absolute;
    bottom: 1.2rem;
    font-size: .72rem;
    opacity: .3;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
 
  .card-back-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    text-align: center;
  }
  .cb-item label {
    display: block;
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--muted);
    margin-bottom: .25rem;
    font-weight: 700;
  }
  .cb-item .val {
    font-family: var(--mono);
    font-size: 1.1rem;
    font-weight: 500;
  }
  .cb-item:nth-child(1) .val { color: var(--accent); }
  .cb-item:nth-child(2) .val { color: var(--accent2); }
  .cb-item:nth-child(3) .val { color: var(--correct); }
  .cb-trans { margin-top: 1.2rem; color: var(--muted); font-size: .9rem; font-style: italic; }
 
  .fc-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .fc-btn {
    padding: .7rem 1.8rem;
    border-radius: 8px;
    border: none;
    font-family: var(--sans);
    font-weight: 600;
    font-size: .9rem;
    cursor: pointer;
    transition: all .15s;
  }
  .fc-btn-next { background: var(--ink); color: white; }
  .fc-btn-next:hover { background: #333; }
  .fc-btn-shuffle { background: white; color: var(--ink); border: 2px solid var(--border); }
  .fc-btn-shuffle:hover { border-color: var(--accent2); color: var(--accent2); }
  .fc-btn-reset { background: white; color: var(--muted); border: 2px solid var(--border); }
 
  /* ──── QUIZ VIEW ──── */
  .quiz-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1rem;
  }
 
  .quiz-score-bar {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-family: var(--mono);
    font-size: .85rem;
  }
  .score-good { color: var(--correct); font-weight: 600; }
  .score-bad  { color: var(--wrong);  font-weight: 600; }
 
  .quiz-card {
    width: 100%;
    max-width: 600px;
    background: white;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 24px rgba(0,0,0,.07);
  }
 
  .quiz-q-label {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    font-weight: 700;
    margin-bottom: .5rem;
  }
  .quiz-question {
    font-family: var(--display);
    font-size: 2.8rem;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: .3rem;
    line-height: 1;
  }
  .quiz-trans { font-size: .88rem; color: var(--muted); margin-bottom: 1.5rem; }
 
  .quiz-ask {
    font-size: .9rem;
    font-weight: 600;
    margin-bottom: .8rem;
    color: var(--ink);
  }
  .quiz-ask em { color: var(--accent2); font-style: normal; }
 
  .quiz-input {
    width: 100%;
    padding: .75rem 1rem;
    border: 2px solid var(--border);
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 1.1rem;
    outline: none;
    transition: border-color .2s;
    margin-bottom: .5rem;
  }
  .quiz-input:focus { border-color: var(--accent2); }
  .quiz-input.correct { border-color: var(--correct); background: #f0faf4; color: var(--correct); }
  .quiz-input.wrong   { border-color: var(--wrong);   background: #fff2f0; color: var(--wrong); }
 
  .quiz-feedback {
    font-size: .88rem;
    min-height: 1.4rem;
    font-weight: 500;
    margin-bottom: .8rem;
  }
  .quiz-feedback.ok  { color: var(--correct); }
  .quiz-feedback.bad { color: var(--wrong);   }
 
  .quiz-submit {
    width: 100%;
    padding: .8rem;
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 8px;
    font-family: var(--sans);
    font-weight: 700;
    font-size: .95rem;
    cursor: pointer;
    transition: background .15s;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .quiz-submit:hover { background: #333; }
  .quiz-submit:disabled { background: var(--muted); cursor: default; }
 
  .quiz-type-sel {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .qtype-btn {
    padding: .4rem .9rem;
    border: 2px solid var(--border);
    border-radius: 6px;
    background: white;
    font-size: .78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .5px;
    cursor: pointer;
    color: var(--muted);
    transition: all .15s;
  }
  .qtype-btn.active { background: var(--accent2); border-color: var(--accent2); color: white; }
 
  .results-box {
    text-align: center;
    background: white;
    border-radius: 16px;
    padding: 3rem 2rem;
    max-width: 460px;
    width: 100%;
    box-shadow: 0 2px 24px rgba(0,0,0,.07);
  }
  .results-emoji { font-size: 3rem; margin-bottom: 1rem; }
  .results-title { font-family: var(--display); font-size: 2.5rem; letter-spacing: 2px; margin-bottom: .5rem; }
  .results-score { font-family: var(--mono); font-size: 1.1rem; color: var(--muted); margin-bottom: 2rem; }
  .results-score strong { color: var(--ink); font-size: 1.5rem; }
 
  /* ──── EMPTY STATE ──── */
  .empty { text-align: center; padding: 4rem; color: var(--muted); }
  .empty svg { margin-bottom: 1rem; opacity: .3; }
 
  /* ──── RESPONSIVE ──── */
  @media(max-width:600px) {
    .verb-table thead { display: none; }
    .verb-table, .verb-table tbody, .verb-table tr, .verb-table td { display: block; width: 100%; }
    .verb-table tr { margin-bottom: .5rem; border-radius: 8px; overflow: hidden; }
    .verb-table td { padding: .5rem 1rem; }
    .card-word { font-size: 2.5rem; }
    .quiz-question { font-size: 2rem; }
  }
 
  /* animations */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(12px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .verb-table tbody tr { animation: fadeUp .2s ease both; }
  .view.active { animation: fadeUp .25s ease both; }
</style>
</head>
<body>
 
<header>
  <div class="logo"><span>Starke</span> VERBEN</div>
  <nav>
    <button class="tab-btn active" onclick="switchView('table')">📋 Liste</button>
    <button class="tab-btn" onclick="switchView('flash')">🃏 Flashcards</button>
    <button class="tab-btn" onclick="switchView('quiz')">✏️ Quiz</button>
  </nav>
</header>
 
<div class="hero">
  <h1>Verbes <em>irréguliers</em><br>en allemand</h1>
  <p>Infinitiv · Präteritum · Partizip II</p>
</div>
 
<main>
 
  <!-- ══════════ TABLE VIEW ══════════ -->
  <section class="view active" id="view-table">
    <div class="controls">
      <div class="search-wrap">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" id="searchInput" placeholder="Rechercher un verbe…" oninput="filterTable()">
      </div>
      <div class="filter-group" id="catFilters"></div>
    </div>
    <div class="count-label" id="countLabel"></div>
    <table class="verb-table">
      <thead>
        <tr>
          <th>Infinitiv</th>
          <th>Präteritum</th>
          <th>Partizip II</th>
          <th>Traduction</th>
          <th>Catégorie</th>
        </tr>
      </thead>
      <tbody id="verbTableBody"></tbody>
    </table>
    <div class="empty" id="emptyState" style="display:none">
      <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6M11 8v6"/></svg>
      <p>Aucun verbe trouvé</p>
    </div>
  </section>
 
  <!-- ══════════ FLASHCARD VIEW ══════════ -->
  <section class="view" id="view-flash">
    <div class="fc-wrapper">
      <div style="width:100%;max-width:560px;display:flex;justify-content:space-between;align-items:center">
        <div class="fc-counter" id="fcCounter">1 / 60</div>
        <div style="display:flex;gap:.5rem">
          <button class="fc-btn fc-btn-shuffle" onclick="shuffleCards()">🔀 Mélanger</button>
          <button class="fc-btn fc-btn-reset" onclick="resetCards()">↩ Reset</button>
        </div>
      </div>
      <div class="fc-progress"><div class="fc-progress-bar" id="fcBar" style="width:0%"></div></div>
 
      <div class="card" id="flashCard" onclick="flipCard()">
        <div class="card-inner">
          <div class="card-face card-front">
            <div class="card-hint">Infinitiv</div>
            <div class="card-word" id="fcWord">—</div>
            <div class="card-sub" id="fcSub">—</div>
            <div class="card-flip-hint">Cliquer pour retourner</div>
          </div>
          <div class="card-face card-back">
            <div class="card-hint" style="color:var(--muted)">Conjugaisons</div>
            <div class="card-back-grid" id="fcBack">
              <div class="cb-item"><label>Infinitiv</label><div class="val" id="fcBI">—</div></div>
              <div class="cb-item"><label>Präteritum</label><div class="val" id="fcBP">—</div></div>
              <div class="cb-item"><label>Partizip II</label><div class="val" id="fcBPP">—</div></div>
            </div>
            <div class="cb-trans" id="fcBTrans">—</div>
          </div>
        </div>
      </div>
 
      <div class="fc-btns">
        <button class="fc-btn fc-btn-next" onclick="prevCard()">← Précédent</button>
        <button class="fc-btn fc-btn-next" onclick="nextCard()">Suivant →</button>
      </div>
    </div>
  </section>
 
  <!-- ══════════ QUIZ VIEW ══════════ -->
  <section class="view" id="view-quiz">
    <div class="quiz-wrapper">
      <div class="quiz-type-sel" id="quizTypeSel"></div>
      <div class="quiz-score-bar">
        <span>Score :</span>
        <span class="score-good" id="scoreGood">✓ 0</span>
        <span class="score-bad"  id="scoreBad">✗ 0</span>
        <span style="color:var(--muted)" id="scoreTotal">/ 0</span>
      </div>
      <div class="quiz-card" id="quizCard">
        <div class="quiz-q-label">Verbe à conjuguer</div>
        <div class="quiz-question" id="quizQuestion">—</div>
        <div class="quiz-trans"    id="quizTrans">—</div>
        <div class="quiz-ask"      id="quizAsk">—</div>
        <input class="quiz-input"  id="quizInput" type="text" placeholder="Votre réponse…" onkeydown="quizKey(event)" autocomplete="off" autocorrect="off" spellcheck="false">
        <div class="quiz-feedback" id="quizFeedback"></div>
        <button class="quiz-submit" id="quizSubmit" onclick="checkAnswer()">Vérifier</button>
      </div>
      <div class="results-box" id="resultsBox" style="display:none">
        <div class="results-emoji" id="resultsEmoji">🎉</div>
        <div class="results-title">Résultat</div>
        <div class="results-score" id="resultsScore"></div>
        <button class="fc-btn fc-btn-next" onclick="restartQuiz()">Recommencer</button>
      </div>
    </div>
  </section>
 
</main>
 
<script>
// ════════════════════════════════════════════
//  DATA
// ════════════════════════════════════════════
const verbs = [
  // Mouvement
  { inf:"fahren",    pret:"fuhr",      part:"gefahren",    trans:"conduire / aller (véhicule)", cat:"Mouvement" },
  { inf:"fliegen",   pret:"flog",      part:"geflogen",    trans:"voler",                       cat:"Mouvement" },
  { inf:"gehen",     pret:"ging",      part:"gegangen",    trans:"aller / marcher",              cat:"Mouvement" },
  { inf:"kommen",    pret:"kam",       part:"gekommen",    trans:"venir",                        cat:"Mouvement" },
  { inf:"laufen",    pret:"lief",      part:"gelaufen",    trans:"courir / marcher",             cat:"Mouvement" },
  { inf:"reiten",    pret:"ritt",      part:"geritten",    trans:"monter à cheval",              cat:"Mouvement" },
  { inf:"schwimmen", pret:"schwamm",   part:"geschwommen", trans:"nager",                        cat:"Mouvement" },
  { inf:"steigen",   pret:"stieg",     part:"gestiegen",   trans:"monter",                       cat:"Mouvement" },
  { inf:"ziehen",    pret:"zog",       part:"gezogen",     trans:"tirer / déménager",            cat:"Mouvement" },
  { inf:"fallen",    pret:"fiel",      part:"gefallen",    trans:"tomber / plaire",              cat:"Mouvement" },
  // Perception
  { inf:"sehen",     pret:"sah",       part:"gesehen",     trans:"voir",                         cat:"Perception" },
  { inf:"hören",     pret:"hörte",     part:"gehört",      trans:"entendre",                     cat:"Perception" },
  { inf:"riechen",   pret:"roch",      part:"gerochen",    trans:"sentir (odorat)",              cat:"Perception" },
  { inf:"fühlen",    pret:"fühlte",    part:"gefühlt",     trans:"ressentir / toucher",          cat:"Perception" },
  { inf:"schlagen",  pret:"schlug",    part:"geschlagen",  trans:"frapper",                      cat:"Perception" },
  // Communication
  { inf:"rufen",     pret:"rief",      part:"gerufen",     trans:"appeler / crier",              cat:"Communication" },
