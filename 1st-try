// ════════════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════════════
function switchView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-'+id).classList.add('active');
  event.currentTarget.classList.add('active');
  if (id === 'flash') renderFlashCard();
  if (id === 'quiz')  renderQuizCard();
}
 
// ════════════════════════════════════════════
//  TABLE VIEW
// ════════════════════════════════════════════
const categories = [...new Set(verbs.map(v => v.cat))];
let activeCategory = 'Tous';
 
function buildCatFilters() {
  const el = document.getElementById('catFilters');
  const all = ['Tous', ...categories];
  el.innerHTML = all.map(c =>
    `<button class="filter-btn${c==='Tous'?' active':''}" onclick="setCategory('${c}',this)">${c}</button>`
  ).join('');
}
 
function setCategory(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterTable();
}
 
function filterTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const tbody = document.getElementById('verbTableBody');
  const filtered = verbs.filter(v => {
    const matchCat = activeCategory === 'Tous' || v.cat === activeCategory;
    const matchQ = !q || v.inf.includes(q) || v.pret.includes(q) || v.part.includes(q) || v.trans.toLowerCase().includes(q);
    return matchCat && matchQ;
  });
 
  document.getElementById('countLabel').innerHTML =
    `<strong>${filtered.length}</strong> verbe${filtered.length!==1?'s':''} affiché${filtered.length!==1?'s':''}`;
 
  tbody.innerHTML = '';
  document.getElementById('emptyState').style.display = filtered.length ? 'none' : 'block';
 
  filtered.forEach((v, i) => {
    const tr = document.createElement('tr');
    tr.style.animationDelay = (i * 0.02) + 's';
    tr.innerHTML = `
      <td><span class="v-inf">${v.inf}</span></td>
      <td><span class="v-pret">${v.pret}</span></td>
      <td><span class="v-part">${v.part}</span></td>
      <td class="v-trans">${v.trans}</td>
      <td><span class="v-cat">${v.cat}</span></td>
    `;
    tbody.appendChild(tr);
  });
}
 
// ════════════════════════════════════════════
//  FLASHCARD VIEW
// ════════════════════════════════════════════
let fcDeck = [...verbs];
let fcIdx  = 0;
let fcFlipped = false;
 
function shuffleCards() {
  fcDeck = [...verbs].sort(() => Math.random() - .5);
  fcIdx = 0; fcFlipped = false;
  document.getElementById('flashCard').classList.remove('flipped');
  renderFlashCard();
}
 
function resetCards() {
  fcDeck = [...verbs];
  fcIdx = 0; fcFlipped = false;
  document.getElementById('flashCard').classList.remove('flipped');
  renderFlashCard();
}
 
function renderFlashCard() {
  const v = fcDeck[fcIdx];
  document.getElementById('fcWord').textContent = v.inf;
  document.getElementById('fcSub').textContent  = v.trans;
  document.getElementById('fcBI').textContent   = v.inf;
  document.getElementById('fcBP').textContent   = v.pret;
  document.getElementById('fcBPP').textContent  = v.part;
  document.getElementById('fcBTrans').textContent = v.trans;
  document.getElementById('fcCounter').textContent = `${fcIdx+1} / ${fcDeck.length}`;
  document.getElementById('fcBar').style.width = ((fcIdx+1)/fcDeck.length*100)+'%';
}
 
function flipCard() {
  fcFlipped = !fcFlipped;
  document.getElementById('flashCard').classList.toggle('flipped', fcFlipped);
}
 
function nextCard() {
  if (fcIdx < fcDeck.length - 1) { fcIdx++; fcFlipped = false; document.getElementById('flashCard').classList.remove('flipped'); renderFlashCard(); }
}
function prevCard() {
  if (fcIdx > 0) { fcIdx--; fcFlipped = false; document.getElementById('flashCard').classList.remove('flipped'); renderFlashCard(); }
}
 
// ════════════════════════════════════════════
//  QUIZ VIEW
// ════════════════════════════════════════════
const quizTypes = [
  { id:'pret', label:'Préteritum',  ask: v => `Quel est le <em>Präteritum</em> de « ${v.inf} » ?`,  answer: v => v.pret  },
  { id:'part', label:'Partizip II', ask: v => `Quel est le <em>Partizip II</em> de « ${v.inf } » ?`, answer: v => v.part  },
  { id:'inf',  label:'Infinitiv',   ask: v => `Quel est l'<em>infinitif</em> de « ${v.pret} » (Prät.) ?`, answer: v => v.inf },
];
 
let qTypeIdx    = 0;
let qDeck       = [];
let qIdx        = 0;
let qGood       = 0;
let qBad        = 0;
let qAnswered   = false;
const QUIZ_LEN  = 15;
 
function buildQuizTypes() {
  const el = document.getElementById('quizTypeSel');
  el.innerHTML = quizTypes.map((t,i) =>
    `<button class="qtype-btn${i===0?' active':''}" onclick="setQType(${i},this)">${t.label}</button>`
  ).join('');
}
 
function setQType(i, btn) {
  qTypeIdx = i;
  document.querySelectorAll('.qtype-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  restartQuiz();
}
 
function restartQuiz() {
  qDeck     = [...verbs].sort(() => Math.random()-.5).slice(0, QUIZ_LEN);
  qIdx      = 0; qGood = 0; qBad = 0; qAnswered = false;
  document.getElementById('resultsBox').style.display  = 'none';
  document.getElementById('quizCard').style.display    = 'block';
  updateScoreUI();
  renderQuizCard();
}
 
function renderQuizCard() {
  const v  = qDeck[qIdx];
  const qt = quizTypes[qTypeIdx];
  document.getElementById('quizQuestion').textContent = qTypeIdx===2 ? v.pret : v.inf;
  document.getElementById('quizTrans').textContent    = v.trans;
  document.getElementById('quizAsk').innerHTML        = qt.ask(v);
  const inp = document.getElementById('quizInput');
  inp.value = ''; inp.className = 'quiz-input'; inp.disabled = false; inp.focus();
  document.getElementById('quizFeedback').textContent = '';
  document.getElementById('quizFeedback').className   = 'quiz-feedback';
  document.getElementById('quizSubmit').textContent   = 'Vérifier';
  document.getElementById('quizSubmit').disabled      = false;
  qAnswered = false;
}
 
function normalize(s) { return s.trim().toLowerCase().replace(/\s+/g,' '); }
 
function checkAnswer() {
  if (qAnswered) { nextQuestion(); return; }
  const v      = qDeck[qIdx];
  const qt     = quizTypes[qTypeIdx];
  const inp    = document.getElementById('quizInput');
  const user   = normalize(inp.value);
  const correct= normalize(qt.answer(v));
  qAnswered    = true;
 
  if (user === correct) {
    qGood++;
    inp.classList.add('correct');
    document.getElementById('quizFeedback').textContent = '✓ Bravo !';
    document.getElementById('quizFeedback').className   = 'quiz-feedback ok';
  } else {
    qBad++;
    inp.classList.add('wrong');
    document.getElementById('quizFeedback').textContent = `✗ Réponse : ${qt.answer(v)}`;
    document.getElementById('quizFeedback').className   = 'quiz-feedback bad';
  }
  inp.disabled = true;
  document.getElementById('quizSubmit').textContent = qIdx < qDeck.length-1 ? 'Question suivante →' : 'Voir le résultat →';
  updateScoreUI();
}
 
function nextQuestion() {
  qIdx++;
  if (qIdx >= qDeck.length) { showResults(); return; }
  renderQuizCard();
}
 
function updateScoreUI() {
  document.getElementById('scoreGood').textContent  = `✓ ${qGood}`;
  document.getElementById('scoreBad').textContent   = `✗ ${qBad}`;
  document.getElementById('scoreTotal').textContent = `/ ${qIdx + (qAnswered?1:0)}`;
}
 
function showResults() {
  document.getElementById('quizCard').style.display   = 'none';
  document.getElementById('resultsBox').style.display = 'block';
  const pct = Math.round(qGood / qDeck.length * 100);
  const emoji = pct >= 80 ? '🏆' : pct >= 50 ? '💪' : '📚';
  document.getElementById('resultsEmoji').textContent = emoji;
  document.getElementById('resultsScore').innerHTML =
    `<strong>${qGood} / ${qDeck.length}</strong><br>${pct}% de réussite`;
}
 
function quizKey(e) { if (e.key === 'Enter') checkAnswer(); }
 
// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
buildCatFilters();
filterTable();
renderFlashCard();
buildQuizTypes();
restartQuiz();
</script>
